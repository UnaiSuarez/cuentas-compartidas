# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local al repositorio (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# Firebase — obtenlos en console.firebase.google.com
# Proyecto → Configuración del proyecto → Tus apps → Web → Mostrar config SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
